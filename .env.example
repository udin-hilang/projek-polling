# IMAP Configuration
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-email@yourdomain.com
IMAP_PASSWORD=your-app-password

# OTP Configuration
OTP_SENDER=noreply@danantaraindonesiacx100.com

# Polling Configuration
EMAIL_DOMAIN=yourdomain.com          # Custom domain for generated emails (overrides IMAP_EMAIL domain)
MAX_VOTES=0                          # Max votes (0 = unlimited)
CLOUDFLARE_WAIT=60                   # Max seconds to wait for Cloudflare challenge
HEADLESS=false                       # Run in headless mode (true/false)
